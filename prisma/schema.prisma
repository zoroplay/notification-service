// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sms_Records {
  id              Int      @id @default(autoincrement())
  provider        String
  senderID        String
  receiverNumber  String
  message         String
  gatewayResponse String?
  trackingId      String?
  status          Boolean
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
}

model Settings {
  id          Int      @id @default(autoincrement())
  clientID    Int      @map("client_id")
  displayName String
  gatewayName String
  senderID    String
  apiKey      String
  username    String
  password    String
  status      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sms_provider_settings")
}

model Notifications {
  id          Int      @id @default(autoincrement())
  userID      Int      @map("user_id")
  description String
  title       String
  status      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

model NotificationMessage {
  notification_id         Int      @id @default(autoincrement())
  client_id  Int      @map("client_id")
  user_id    Int      @map("user_id")
  content    String   @db.Text
  title      String
  status     Int      @default(1)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@map("notification_messages")
}

model User_Messages {
  id         Int      @id @default(autoincrement())
  user_id    Int      @map("user_id")
  client_id  Int      @map("client_id")
  message_id Int      @map("message_id")
  status     Int      @default(1)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@map("user_messages")
}

model Chat {
  chat_id               String               @id @default(uuid()) @db.Uuid
  client_id             Int                  @map("client_id")
  name                  String?              @db.VarChar(100)
  chat_type             ChatType             @default(DIRECT)
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @updatedAt @db.Timestamptz(6)
  deleted_at            DateTime?            @db.Timestamptz(6)
  messages              Message[]
  participants          ChatParticipant[]
  unread_message_counts UnreadMessageCount[]

  @@map("chats")
}

model ChatParticipant {
  chat_id      String    @db.Uuid
  user_id      Int
  client_id    Int       @map("client_id")
  joined_at    DateTime  @default(now()) @db.Timestamptz(6)
  is_admin     Boolean   @default(false)
  is_active    Boolean   @default(true)
  left_at      DateTime? @db.Timestamptz(6)
  unread_count Int       @default(0)

  chat Chat @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)

  @@id([chat_id, user_id])
  @@index([user_id]) // Keep index for performance
  @@map("chat_participants")
}

model Message {
  message_id String        @id @default(uuid()) @db.Uuid
  chat_id    String        @db.Uuid
  sender_id  Int           @map("sender_id") // Reference to user in Profile Service
  client_id  Int           @map("client_id")
  content    String
  type       MessageType   @default(TEXT)
  status     MessageStatus @default(SENT)
  created_at DateTime      @default(now()) @db.Timestamptz(6)
  updated_at DateTime      @updatedAt @db.Timestamptz(6)
  deleted_at DateTime?     @db.Timestamptz(6)

  duration  Int?
  file_url  String?
  file_size Int?
  file_type String?

  chat          Chat          @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)
  read_receipts MessageRead[]

  @@index([chat_id])
  @@index([sender_id])
  @@map("messages")
}

model MessageRead {
  message_id String    @db.Uuid
  user_id    String    @db.Uuid
  read_at    DateTime? @db.Timestamptz(6)

  message Message @relation(fields: [message_id], references: [message_id], onDelete: Cascade)

  @@id([message_id, user_id])
  @@index([user_id])
  @@map("message_reads")
}

enum MessageType {
  TEXT
  SYSTEM
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ

  @@map("message_status")
}

model UnreadMessageCount {
  user_id      String   @db.Uuid
  chat_id      String   @db.Uuid
  count        Int      @default(0)
  last_read_at DateTime @default(now()) @db.Timestamptz(6)

  chat Chat @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)

  @@id([user_id, chat_id])
  @@index([user_id])
  @@map("unread_message_counts")
}

enum ChatType {
  DIRECT
  GROUP
  BROADCAST

  @@map("chat_type")
}

enum Platform {
  WEB
  MOBILE
  ANDROID
  IOS
  RETAIL

  @@map("platform")
}

model PushSubscription {
  subscription_id String   @id @default(uuid()) @db.Uuid
  user_id         Int
  client_id       Int      @map("client_id")
  endpoint        String
  p256dh          String?
  auth            String?
  platform        Platform
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @updatedAt @db.Timestamptz(6)

  @@unique([user_id, endpoint, client_id])
  @@index([user_id]) // Keep index for performance
  @@map("push_subscriptions")
}
